rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isAuthenticated() && request.auth.token.admin == true;
    }

    function isTimestamp(value) {
      return value is timestamp;
    }

    function validateString(value, minLen, maxLen) {
      return value is string && value.size() >= minLen && value.size() <= maxLen;
    }

    // Allow a user to add/remove only themselves from another user's followers list
    function isFollowersOnlySelfUpdate(userId) {
      return isAuthenticated() &&
             request.auth.uid != userId &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['followers']) &&
             request.resource.data.followers is list;
    }

    // Allow authenticated users to interact with posts (like / comment count updates)
    function isPostInteractionUpdate() {
      return isAuthenticated() &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes', 'commentCount', 'repostCount', 'videoViewCount']) &&
             (!('likes' in request.resource.data) || request.resource.data.likes is list) &&
             (!('commentCount' in request.resource.data) || request.resource.data.commentCount is int) &&
             (!('repostCount' in request.resource.data) || request.resource.data.repostCount is int) &&
             (!('videoViewCount' in request.resource.data) || request.resource.data.videoViewCount is int);
    }

    // Allow authenticated users to like/unlike comments
    function isCommentLikeUpdate() {
      return isAuthenticated() &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['likes']) &&
             request.resource.data.likes is list;
    }

    // Allow comment authors to edit their comments
    function isCommentEditUpdate() {
      return isAuthenticated() &&
             request.resource.data.diff(resource.data).changedKeys().hasOnly(['content', 'updatedAt', 'isEdited', 'editedAt']) &&
             validateString(request.resource.data.content, 1, 2000) &&
             request.resource.data.isEdited is bool &&
             isTimestamp(request.resource.data.updatedAt) &&
             (request.resource.data.editedAt == null || isTimestamp(request.resource.data.editedAt));
    }
    
    // Allow read/write only for authenticated users
    match /users/{userId} {
      allow read: if true; // Public profile viewing
      allow create, delete: if isOwner(userId);
      allow update: if isOwner(userId) || isFollowersOnlySelfUpdate(userId);
      
      // Notifications sub-collection
      match /userNotifications/{notificationId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) &&
                         validateString(request.resource.data.title, 1, 100) &&
                         validateString(request.resource.data.body, 1, 500) &&
                         isTimestamp(request.resource.data.createdAt);
        allow update: if isOwner(userId) &&
                         request.resource.data.keys().hasOnly(['isRead', 'readAt']);
      }
    }
    
    // Posts collection (TEMPORARY SIMPLIFIED RULES FOR TESTING)
    match /posts/{postId} {
      allow read: if true; // Public posts
      allow create: if isAuthenticated() &&
                       request.resource.data.authorId == request.auth.uid;
      allow update: if isAuthenticated() &&
                       (resource.data.authorId == request.auth.uid || isAdmin() || isPostInteractionUpdate());
      allow delete: if isAuthenticated() &&
                       (resource.data.authorId == request.auth.uid || isAdmin());
    }
    
    // Comments collection
    match /comments/{commentId} {
      allow read: if true; // Public comments
      allow create: if isAuthenticated() &&
                       request.resource.data.authorId == request.auth.uid &&
                       validateString(request.resource.data.content, 1, 2000) &&
                       request.resource.data.postId is string &&
                       isTimestamp(request.resource.data.createdAt);
      allow update: if ((resource.data.authorId == request.auth.uid && isCommentEditUpdate()) || isCommentLikeUpdate() || isAdmin()) &&
                       request.resource.data.authorId == resource.data.authorId &&
                       request.resource.data.postId == resource.data.postId &&
                       request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if resource.data.authorId == request.auth.uid || isAdmin();
    }
    
    // Conversations (Direct Messaging)
    match /conversations/{conversationId} {
      allow read: if isAuthenticated() &&
                     (resource.data.participantIds == null || resource.data.participantIds.size() == 0 ||
                      request.auth.uid in resource.data.participantIds) &&
                     conversationId.matches('^[a-zA-Z0-9_]+_[a-zA-Z0-9_]+$');
      allow create: if isAuthenticated() &&
                       request.resource.data.participantIds is list &&
                       request.resource.data.participantIds.size() == 2 &&
                       request.auth.uid in request.resource.data.participantIds &&
                       isTimestamp(request.resource.data.createdAt);
      allow update: if isAuthenticated() &&
                       ((resource.data.participantIds == null || resource.data.participantIds.size() == 0) ||
                        request.auth.uid in resource.data.participantIds) &&
                       (request.resource.data.participantIds == resource.data.participantIds ||
                        !request.resource.data.diff(resource.data).changedKeys().hasAny(['participantIds']));
      allow delete: if isAuthenticated() &&
                       ((resource.data.participantIds == null || resource.data.participantIds.size() == 0) ||
                        request.auth.uid in resource.data.participantIds);
      match /messages/{messageId} {
        allow read: if isAuthenticated() &&
                       ((get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds == null || 
                         get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.size() == 0) ||
                        request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
        allow create: if isAuthenticated() &&
                        request.auth.uid == request.resource.data.senderId &&
                        validateString(request.resource.data.content, 1, 5000) &&
                        (isTimestamp(request.resource.data.sentAt) || isTimestamp(request.resource.data.createdAt)) &&
                        ((get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds == null ||
                          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.size() == 0) ||
                         request.resource.data.senderId in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
        allow delete: if isAuthenticated() &&
                        ((get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds == null ||
                          get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds.size() == 0) ||
                         request.auth.uid in get(/databases/$(database)/documents/conversations/$(conversationId)).data.participantIds);
      }
    }
    
    // Notifications (top-level collection)
    match /notifications/{userId}/userNotifications/{notificationId} {
      allow read: if isOwner(userId);
      allow create: if isAuthenticated() &&
                       request.resource.data.userId == userId &&
                       request.resource.data.triggeredBy == request.auth.uid &&
                       validateString(request.resource.data.type, 1, 50) &&
                       validateString(request.resource.data.content, 1, 500) &&
                       validateString(request.resource.data.triggeredByName, 1, 100) &&
                       isTimestamp(request.resource.data.createdAt);
      allow update: if isOwner(userId) &&
                       request.resource.data.diff(resource.data).changedKeys().hasOnly(['isRead', 'readAt']);
      allow delete: if isOwner(userId);
    }
    
    // Default deny for anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
